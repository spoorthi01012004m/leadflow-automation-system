    {
      "parameters": {
        "jsCode": "const leads = items.map(item => item.json);\n\nconst urgencyCount = {};\nconst productCount = {};\n\n// Count urgency and product\nfor (const lead of leads) {\n\n  const urgency = lead.urgency || \"unknown\";\n  urgencyCount[urgency] =\n    (urgencyCount[urgency] || 0) + 1;\n\n  const product = lead.product || \"unknown\";\n  productCount[product] =\n    (productCount[product] || 0) + 1;\n}\n\n// Get top 5 recent leads\nconst recentLeads = leads\n  .sort((a, b) =>\n    new Date(b.createdAt) -\n    new Date(a.createdAt)\n  )\n  .slice(0, 5);\n\n// Build digest message\nlet digestMessage = `DAILY LEAD DIGEST\\n\\n`;\n\ndigestMessage += `Count by Urgency\\n`;\n\nfor (const [key, value] of Object.entries(urgencyCount)) {\n  digestMessage += `${key}: ${value}\\n`;\n}\n\ndigestMessage += `\\nCount by Product\\n`;\n\nfor (const [key, value] of Object.entries(productCount)) {\n  digestMessage += `${key}: ${value}\\n`;\n}\n\ndigestMessage += `\\nTop 5 Recent Leads\\n`;\n\nrecentLeads.forEach((lead, index) => {\n  digestMessage += `${index + 1}. ${lead.customerName} - ${lead.message}\\n`;\n});\n\nreturn [\n  {\n    json: {\n      digest: digestMessage\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
