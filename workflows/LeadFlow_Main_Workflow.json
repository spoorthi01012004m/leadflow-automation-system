      "parameters": {
        "jsCode": "const spamKeywords = [\n  \"buy now\",\n  \"free money\",\n  \"click here\",\n  \"lottery\",\n  \"casino\",\n  \"win cash\"\n];\n\nconst leadMessage = $json.body.message.toLowerCase();\n\nconst isSpamLead = spamKeywords.some(keyword =>\n  leadMessage.includes(keyword)\n);\n\nreturn [\n  {\n    json: {\n      ...$json,\n      isSpamLead\n    }\n  }\n];"
      },
